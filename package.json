{
	"name": "n8n-nodes-peak",
	"version": "0.1.6",
	"description": "n8n community node for integrating with the PEAK Accounting Platform",
	"private": false,
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"homepage": "https://github.com/PEAK-Account-Lab/peak-n8n-node",
	"author": {
		"name": "PEAK Account",
		"email": "api@peakengine.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/PEAK-Account-Lab/peak-n8n-node.git"
	},
	"engines": {
		"node": "20"
	},
	"main": "dist/nodes/Peak/Peak.node.js",
	"scripts": {
		"format": "prettier nodes credentials --write",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"clean": "rimraf node_modules package-lock.json dist",
		"n8n:dev": "n8n start",
		"build": "rimraf dist && tsc && gulp build:icons",
    "prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/PEAKApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Peak/Peak.node.js"
		]
	},
	"devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^20.11.30",
    "gulp": "^5.0.0",
    "prettier": "3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "5.9.3"
  },
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"overrides": {
		"change-case": "4.1.2",
    "isolated-vm": "5.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
